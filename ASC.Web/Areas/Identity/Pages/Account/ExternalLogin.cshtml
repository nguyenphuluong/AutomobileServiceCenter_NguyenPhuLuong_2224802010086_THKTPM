@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Register";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col s12 m6 offset-m3">
            <form asp-page-handler="Confirmation"
                  asp-route-returnUrl="@Model.ReturnUrl"
                  method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <p>
                    You've successfully authenticated with
                    <strong>@Model.ProviderDisplayName</strong>.
                    Please enter email below to finish logging in.
                </p>

                <div class="input-field">
                    <input asp-for="Input.Email" type="email" readonly />
                    <label asp-for="Input.Email"></label>
                </div>

                <div class="row center">
                    <button class="btn waves-effect waves-light" type="submit">
                        Register
                        <i class="material-icons right">send</i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}