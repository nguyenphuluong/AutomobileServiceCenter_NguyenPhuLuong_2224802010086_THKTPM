@page
@model ASC.Web.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
    Layout = "_Layout";
}

<div class="container">
    <div class="row">
        <form method="post" class="form-horizontal">
            <div asp-validation-summary="All" class="text-danger"></div>

            <input asp-for="Input.UserId" type="hidden" />
            <input asp-for="Input.Code" type="hidden" />

            <div class="row">
                <div class="input-field col s12">
                    <input asp-for="Input.Password" type="password" class="validate" />
                    <label asp-for="Input.Password"></label>
                    <span asp-validation-for="Input.Password" class="helper-text" data-error="wrong" data-success="right"></span>
                </div>
            </div>

            <div class="row">
                <div class="input-field col s12">
                    <input asp-for="Input.ConfirmPassword" type="password" class="validate" />
                    <label asp-for="Input.ConfirmPassword"></label>
                    <span asp-validation-for="Input.ConfirmPassword" class="helper-text" data-error="wrong" data-success="right"></span>
                </div>
            </div>

            <div class="row center">
                <button class="btn waves-effect waves-light" type="submit">
                    Reset
                    <i class="material-icons right">send</i>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}